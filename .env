# Environment variables declared in this file are NOT automatically loaded by Next.js.
# Next.js loads .env.local in development and production.
# Prisma CLI loads this .env file by default.

# Local SQLite database (development)
DATABASE_URL="file:./dev.db"

# Copy this file to .env.local and fill in your real secrets:
# JWT_SECRET=your-random-secret-key
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
# VISION_API_KEY=sk-...
# VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VISION_MODEL=qwen-vl-plus
# ADMIN_PASSWORD=your-admin-password
