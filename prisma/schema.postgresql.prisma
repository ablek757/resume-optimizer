generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  credits            Int       @default(0)
  subscriptionEndsAt DateTime?
  dailyFreeUses      Int       @default(0)
  lastFreeUseDate    String? // YYYY-MM-DD
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model RedemptionCode {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String // "credits" | "subscription_days"
  value     Int // number of credits or days
  usedBy    String? // user id
  usedAt    DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}
