generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  credits            Int      @default(0)
  subscriptionEndsAt DateTime?
  dailyFreeUses      Int      @default(0)
  lastFreeUseDate    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model RedemptionCode {
  id             String         @id @default(cuid())
  code           String         @unique
  type           String
  value          Int
  usedBy         String?
  usedAt         DateTime?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())
  paymentOrders  PaymentOrder[]
}

model PaymentOrder {
  id                String          @id @default(cuid())
  userId            String
  amount            Float?
  packageName       String?
  packageType       String?
  packageValue      Int?
  screenshot        String
  recognizedText    String?
  status            String
  redemptionCodeId  String?
  redemptionCode    RedemptionCode? @relation(fields: [redemptionCodeId], references: [id])
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model OptimizationHistory {
  id              String   @id @default(cuid())
  userId          String
  jobTitle        String
  jobDescription  String?
  originalText    String
  result          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}
